#version 430 core
layout(local_size_x = 256) in;

layout(std430, binding = 0) readonly buffer TempBuffer
{
    uint tempValues[];
};

layout(std430, binding = 1) buffer DataBuffer
{
    uint values[];
};

uniform uint uN;

void main()
{
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= uN)
    {
        return;
    }

    values[idx] = tempValues[idx];
}
